# FORGE Configuration
# Copy this file to .env and fill in your values

# PostgreSQL Database (required)
FORGE_DB_HOST=localhost
FORGE_DB_PORT=5432
FORGE_DB_USER=forge
FORGE_DB_PASSWORD=
FORGE_DB_NAME=forge

# Anthropic API Key (optional — only needed for Haiku audit agent)
ANTHROPIC_API_KEY=

# SAM.gov API Key (optional — free, register at api.data.gov)
SAM_GOV_API_KEY=

# SMTP Verifier Identity (optional)
FORGE_SMTP_FROM=verify@yourdomain.com
FORGE_SMTP_EHLO=yourdomain.com

# Monitor Service Prefix (optional — for launchd/systemd)
FORGE_SERVICE_PREFIX=com.forge
